# ---------- BACKEND ----------
cat > backend/package.json <<'EOF'
{
  "name": "noemi-nexus-backend",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  }
}
EOF

cat > backend/server.js <<'EOF'
/*
  NOEMI NEXUS — PRIVATE SYSTEM
*/
require('dotenv').config();
const express = require('express');
const cors = require('cors');
const helmet = require('helmet');
const morgan = require('morgan');
const jwt = require('jsonwebtoken');

const app = express();

app.use(helmet());
app.use(cors({ origin: process.env.ALLOWED_ORIGIN || "*" }));
app.use(express.json());
app.use(morgan('combined'));

// ---- simple service auth (API key) ----
function serviceAuth(req, res, next) {
  const key = req.headers['x-api-key'];
  if (!key || key !== process.env.API_KEY) {
    return res.status(401).json({ error: 'Unauthorized' });
  }
  next();
}

// ---- user auth (JWT) ----
function userAuth(req, res, next) {
  const token = (req.headers.authorization || "").split(" ")[1];
  if (!token) return res.status(401).json({ error: 'No token' });
  try {
    req.user = jwt.verify(token, process.env.JWT_SECRET);
    next();
  } catch {
    return res.status(403).json({ error: 'Invalid token' });
  }
}

// ---- health ----
app.get('/api/health', (req, res) => {
  res.json({ status: 'ok', service: 'noemi-nexus-backend' });
});

// ---- demo login (dev only) ----
app.post('/api/login', (req, res) => {
  const { user = 'admin', role = 'owner' } = req.body || {};
  const token = jwt.sign({ user, role }, process.env.JWT_SECRET, { expiresIn: '1h' });
  res.json({ token });
});

// ---- protected feed (stub) ----
app.get('/api/noemi-feed', serviceAuth, async (req, res) => {
  // TODO: merge Google Sheets + chain events
  const rows = [
    { time: new Date().toISOString(), type: 'GOAL', value: 1, source: 'stub' },
    { time: new Date().toISOString(), type: 'FEATURE', value: 1, source: 'stub' }
  ];
  res.json({ rows });
});

// ---- metrics (stub) ----
app.get('/api/metrics', userAuth, (req, res) => {
  res.json({
    activity: 2,
    velocity: 1,
    momentum: 5,
    riskScore: "MEDIUM"
  });
});

const PORT = process.env.PORT || 5000;
app.listen(PORT, () => {
  console.log(`🚀 Backend running on ${PORT}`);
});
EOF

# ---------- FRONTEND ----------
cat > frontend/package.json <<'EOF'
{
  "name": "noemi-nexus-frontend",
