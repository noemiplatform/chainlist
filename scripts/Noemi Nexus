https://github.com/YOUR_USERNAME/noemi-nexus.git#!/bin/bash

PROJECT="noemi-nexus"

echo "🚀 Initializing Noemi Nexus..."

mkdir $PROJECT
cd $PROJECT

# ================= ROOT =================
touch README.md LICENSE.md .env.example

# ================= BACKEND =================
mkdir -p backend/services

touch backend/server.js
touch backend/audit.js
touch backend/ids.js
touch backend/insightEngine.js
touch backend/.env.example

touch backend/services/googleSheets.js
touch backend/services/blockchain.js
touch backend/services/insights.js

# ================= FRONTEND =================
mkdir -p frontend/src

touch frontend/src/App.jsx
touch frontend/package.json

# ================= SMART CONTRACT =================
mkdir contracts
touch contracts/NoemiPlatformCAP.sol

# ================= GITHUB =================
mkdir -p .github/workflows
touch .github/workflows/deploy.yml
touch .github/CODEOWNERS

# ================= README =================
cat <<EOF > README.md
# 🚀 Noemi Nexus

A private enterprise blockchain intelligence system.

## Modules
- Smart Contract Layer (Ethereum ERC-20 + Events)
- Backend API (Node.js + Zero Trust Security)
- Google Sheets Sync Engine
- AI Insight Engine
- Real-time Investor Dashboard

## Ownership
Controlled exclusively by:
- Lashawn Spencer
- Justine Spencer
- Dorothy Aragon

## Status
PRIVATE SYSTEM — AUTHORIZED USE ONLY
EOF

# ================= LICENSE =================
cat <<EOF > LICENSE.md
NOEMI NEXUS — PRIVATE RESTRICTED LICENSE

This system is proprietary and confidential.

No use, modification, distribution, or deployment is allowed without written authorization from:

- Lashawn Spencer
- Justine Spencer
- Dorothy Aragon

Unauthorized use is strictly prohibited.
EOF

# ================= ENV TEMPLATE =================
cat <<EOF > backend/.env.example
RPC_URL=
CONTRACT_ADDRESS=
SHEET_ID=
API_KEY=
JWT_SECRET=
OPENAI_KEY=
EOF

# ================= CODE OWNERS =================
cat <<EOF > .github/CODEOWNERS
* @LashawnSpencer @JustineSpencer @DorothyAragon
EOF

echo "✅ Noemi Nexus structure created successfully!"
echo "📁 Ready for GitHub upload"init-noemi-nexus.sh-noemi-nexus.shchmod +x init-noemi-nexus.sh
./init-noemi-nexus.sh

cd noemi-nexus

git init
git add .
git commit -m "Initial Noemi Nexus enterprise infrastructure"

git branch -M main
git remote add origin https://github.com/YOUR_USERNAME/noemi-nexus.git
git push -u origin m#!/usr/bin/env bash

set -euo pipefail

#############################################
# Noemi Nexus Post Export Pipeline
# Hardened build + export stage
# Author: Noemi Platform CAP System
#############################################

echo "🚀 [NEXUS] Starting post-export pipeline..."

# ---------- CONFIG ----------
ROOT_DIR="$(pwd)"
OUT_DIR="$ROOT_DIR/out"
LOG_FILE="$ROOT_DIR/nexus-post-export.log"

NODE_BIN=$(command -v node || true)

if [[ -z "$NODE_BIN" ]]; then
  echo "❌ Node.js not found. Aborting."
  exit 1
fi

# ---------- LOGGING ----------
exec > >(tee -a "$LOG_FILE") 2>&1

echo "📦 Working directory: $ROOT_DIR"
echo "📁 Output directory: $OUT_DIR"

# ---------- SAFETY CHECK ----------
if [[ ! -d "$OUT_DIR" ]]; then
  echo "⚠️ Output directory missing, creating..."
  mkdir -p "$OUT_DIR"
fi

# ---------- AUTHORIZED RUN GATE (optional security layer) ----------
# You can extend this later to verify GitHub tokens / signatures
AUTHORIZED_RUN=${NOEMI_AUTHORIZED_RUN:-"true"}

if [[ "$AUTHORIZED_RUN" != "true" ]]; then
  echo "⛔ Unauthorized execution blocked by Nexus policy."
  exit 1
fi

# ---------- PACKAGE.JSON SAFETY PATCH ----------
echo "🔧 Enabling temporary module compatibility patch..."

if [[ -f "package.json" ]]; then
  cp package.json package.json.nexus.backup

  # cross-platform safe node patch (no fragile sed hacks)
  node -e "
    const fs = require('fs');
    const pkg = JSON.parse(fs.readFileSync('package.json','utf8'));

    pkg.type = 'module';

    fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2));
  "
fi

# ---------- BUILD STEPS ----------
echo "⚙️ Running export generation scripts..."

if [[ -f "scripts/generate-sitemap.js" ]]; then
  node scripts/generate-sitemap.js
else
  echo "⚠️ Missing sitemap generator"
fi

if [[ -f "scripts/generate-json.js" ]]; then
  node scripts/generate-json.js
else
  echo "⚠️ Missing JSON generator"
fi

# ---------- OUTPUT NORMALIZATION ----------
echo "🧹 Normalizing output structure..."

if [[ -f "$OUT_DIR/404.html" ]]; then
  echo "📄 404 page detected"
fi

# ensure deterministic timestamps for reproducibility
find "$OUT_DIR" -type f -exec touch -t 200001010000 {} \; || true

# ---------- ARTIFACT HASHING ----------
echo "🔐 Generating integrity manifest..."

MANIFEST="$OUT_DIR/manifest.sha256"
rm -f "$MANIFEST"

if command -v sha256sum >/dev/null 2>&1; then
  (cd "$OUT_DIR" && find . -type f -exec sha256sum {} \;) > "$MANIFEST"
elif command -v shasum >/dev/null 2>&1; then
  (cd "$OUT_DIR" && find . -type f -exec shasum -a 256 {} \;) > "$MANIFEST"
else
  echo "⚠️ No checksum tool found"
fi

# ---------- RESTORE STATE ----------
echo "♻️ Restoring original package.json..."

if [[ -f "package.json.nexus.backup" ]]; then
  mv package.json.nexus.backup package.json
fi

# ---------- FINAL PACKAGING ----------
echo "📦 Finalizing export bundle..."

tar -czf nexus-export.tar.gz out || true

# ---------- DONE ----------
echo "✅ [NEXUS] Post-export pipeline complete"
echo "📌 Log saved to: $LOG_FILE"
echo "📦 Artifact: nexus-export.tar.gz"ainREADME.mdLICENSE.mdchmod +x init-noemi-nexus.sh
./init-noemi-nexus.sh

cd noemi-nexus

git init
git add .
git commit -m "Noemi Nexus enterprise production system"

git branch -M main
git remote add origin https://github.com/YOUR_USERNAME/noemi-nexus.git
git push -u origin mainhttps://github.com/YOUR_USERNAME/noemi-nexus.gitinit-noemi-nexus.sh-noemi-nexus.sh